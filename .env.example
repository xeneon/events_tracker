# ==============================================
# Events Tracker Ingestion CLI — Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values.

# --- Database ---
# PostgreSQL connection string (external DB at 192.168.1.103)
DATABASE_URL=postgresql+asyncpg://events_user:events_password@192.168.1.103:5432/events_tracker

# --- API Keys (for data ingestion) ---
# Calendarific (https://calendarific.com/api) — required for US holiday ingestion
CALENDARIFIC_API_KEY=

# Trakt (https://trakt.tv/oauth/applications) — required for movie/TV ingestion
TRAKT_CLIENT_ID=

# Last.fm (https://www.last.fm/api/account/create) — required for album popularity enrichment
LASTFM_API_KEY=

# --- Google Sheets Export ---
# Google Sheets ID (from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/...)
GOOGLE_SHEET_ID=

# Tab name to write to (default: Sheet1)
GOOGLE_SHEET_TAB=Sheet1

# Path to Google service account credentials JSON file
GOOGLE_CREDENTIALS_FILE=

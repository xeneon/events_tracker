# ==============================================
# Events Tracker — Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values.

# --- Database ---
# PostgreSQL connection string (external DB at 192.168.1.103)
DATABASE_URL=postgresql+asyncpg://events_user:events_password@192.168.1.103:5432/events_tracker

# --- Authentication ---
# Secret key for JWT token signing (change in production!)
JWT_SECRET=change-me-to-a-random-secret-key

# --- Initial Superuser ---
# Created on first run via seed script
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=changeme123

# --- API Keys (for data ingestion) ---
# Trakt (https://trakt.tv/oauth/applications) — required for movie/TV ingestion
TRAKT_CLIENT_ID=
# RAWG (https://rawg.io/apidocs) — required for game ingestion
RAWG_API_KEY=

# --- App Config ---
APP_ENV=development
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://192.168.1.102:3000,http://192.168.1.102
